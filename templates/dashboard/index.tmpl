{{ template "layout" . }}
{{define "title"}}博客文章{{end}}
{{define "content"}}
<div class="articles-container">
    <h1>{{ .content }}</h1>

    {{if .articles}}
        <div class="articles-grid">
            {{range .articles}}
            <div class="article-card">
                <button
                    class="article-btn"
                    onclick="window.location.href='{{.RedirectURL}}'"
                    data-url="{{.RedirectURL}}"
                >
                    <span class="article-title">{{.Title}}</span>
                </button>
                <div class="article-meta">
                    <span class="article-date">{{if .Date}}{{.Date}}{{else}}未设置日期{{end}}</span>
                    <span class="article-author">{{if .Author}}{{.Author}}{{else}}匿名作者{{end}}</span>
                </div>
            </div>
            {{end}}
        </div>
    {{else}}
        <div class="no-articles">
            <p>暂无文章</p>
            <p>开始分享你的知识吧！</p>
        </div>
    {{end}}
</div>

<style>
    .articles-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .articles-container h1 {
        text-align: center;
        color: #2c3e50;
        margin-bottom: 40px;
        font-size: 2.5em;
        border-bottom: 3px solid #3498db;
        padding-bottom: 15px;
    }

    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 25px;
        padding: 20px 0;
    }

    .article-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        border: 1px solid #e1e1e1;
    }

    .article-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }

    .article-btn {
        width: 100%;
        padding: 25px 20px;
        background: linear-gradient(135deg, #3498db, #2980b9);
        color: white;
        border: none;
        cursor: pointer;
        font-size: 18px;
        font-weight: bold;
        text-align: center;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 120px;
    }

    .article-btn:hover {
        background: linear-gradient(135deg, #2980b9, #1c5a7a);
    }

    .article-btn:active {
        transform: scale(0.98);
    }

    .article-title {
        display: block;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding: 0 10px;
    }

    .article-meta {
        padding: 15px 20px;
        background: #f8f9fa;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e1e1e1;
    }

    .article-date {
        font-size: 14px;
        color: #7f8c8d;
    }

    .article-author {
        font-size: 14px;
        color: #3498db;
        font-weight: 500;
    }

    .no-articles {
        text-align: center;
        padding: 60px 20px;
        background: #f8f9fa;
        border-radius: 12px;
        border: 2px dashed #bdc3c7;
        margin-top: 40px;
    }

    .no-articles p {
        font-size: 18px;
        color: #7f8c8d;
        margin: 10px 0;
    }

    .no-articles p:first-child {
        font-size: 24px;
        color: #2c3e50;
        font-weight: bold;
        margin-bottom: 20px;
    }

    /* 响应式设计 */
    @media (max-width: 768px) {
        .articles-grid {
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }

        .article-btn {
            padding: 20px 15px;
            font-size: 16px;
            min-height: 100px;
        }

        .articles-container h1 {
            font-size: 2em;
        }
    }

    @media (max-width: 480px) {
        .articles-grid {
            grid-template-columns: 1fr;
        }

        .article-meta {
            flex-direction: column;
            gap: 8px;
            align-items: flex-start;
        }
    }

    /* 动画效果 */
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .article-card {
        animation: fadeIn 0.5s ease forwards;
    }

    .article-card:nth-child(1) { animation-delay: 0.1s; }
    .article-card:nth-child(2) { animation-delay: 0.2s; }
    .article-card:nth-child(3) { animation-delay: 0.3s; }
    .article-card:nth-child(4) { animation-delay: 0.4s; }
    .article-card:nth-child(5) { animation-delay: 0.5s; }
    .article-card:nth-child(6) { animation-delay: 0.6s; }
</style>

<script>
    // 为文章按钮添加点击效果
    document.addEventListener('DOMContentLoaded', function() {
        const articleButtons = document.querySelectorAll('.article-btn');

        articleButtons.forEach(button => {
            button.addEventListener('click', function(e) {
                // 添加点击反馈
                this.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    this.style.transform = '';
                }, 150);

                // 获取重定向URL
                const redirectURL = this.getAttribute('data-url');
                if (redirectURL) {
                    console.log('跳转到:', redirectURL);
                    // 页面跳转由onclick属性处理
                }
            });

            // 添加键盘支持
            button.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    this.click();
                }
            });
        });

        // 为没有文章的情况添加提示
        const noArticles = document.querySelector('.no-articles');
        if (noArticles) {
            setTimeout(() => {
                noArticles.style.opacity = '1';
                noArticles.style.transform = 'translateY(0)';
            }, 100);
        }
    });

    // 页面加载动画
    window.addEventListener('load', function() {
        document.body.style.opacity = '0';
        document.body.style.transition = 'opacity 0.5s ease';

        setTimeout(() => {
            document.body.style.opacity = '1';
        }, 100);
    });
</script>
{{end}}