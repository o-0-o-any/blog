{{define "layout"}}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{block "title" .}}仪表板{{end}}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #2c3e50;
            padding: 0 20px;
            height: 60px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        .nav-links {
            display: flex;
            gap: 1px;
        }
        .nav-btn {
            background-color: #2c3e50;
            color: white;
            border: none;
            padding: 0 20px;
            height: 60px;
            font-size: 16px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }
        .nav-btn:hover {
            background-color: #34495e;
        }
        .nav-btn:active {
            background-color: #1a252f;
        }
        .back-btn {
            background-color: #3498db;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }
        .back-btn:hover {
            background-color: #2980b9;
        }
        .content {
            padding: 40px;
            text-align: center;
            color: #333;
        }
        @media (max-width: 768px) {
            .navbar {
                flex-direction: column;
                height: auto;
                padding: 10px;
            }
            .nav-links {
                width: 100%;
                margin-bottom: 10px;
            }
            .nav-btn {
                width: 33.33%;
                padding: 10px 0;
                height: auto;
            }
            .back-btn {
                margin-top: 10px;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-links">
            <button class="nav-btn" onclick="goToDashboardIndex()">主页</button>
            <button class="nav-btn" onclick="goToDashboardEdit()">编辑博客</button>
            <button class="nav-btn" onclick="goToDashboardInfo()">个人信息</button>
        </div>
        <button class="back-btn" onclick="goToBlogIndex()">返回博客主页</button>
    </nav>

    <div class="content">
        {{block "content" .}}默认内容{{end}}
    </div>

    <script>
        // 导航到仪表板主页
        function goToDashboardIndex() {
            window.location.href = "/blog/admin/dashboard/index";
        }

        // 导航到编辑博客页面
        function goToDashboardEdit() {
            window.location.href = "/blog/admin/dashboard/edit";
        }

        // 导航到个人信息页面
        function goToDashboardInfo() {
            window.location.href = "/blog/admin/dashboard/info";
        }

        // 返回博客主页
        function goToBlogIndex() {
            window.location.href = "/blog/index";
        }
    </script>
</body>
</html>
{{end}}