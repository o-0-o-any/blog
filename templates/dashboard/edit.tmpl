{{ template "layout" . }}
{{define "title"}}博客编辑{{end}}
{{define "content"}}
<div class="editor-container">
    <h1>博客编辑器</h1>

    <!-- 关键修改：将整个表单包裹在最外层，让title/author输入框也属于表单的一部分 -->
    <form id="blog-form" action="/blog/admin/dashboard/edit" method="POST">
        <!-- 新增：文章标题和作者输入区域 -->
        <div class="article-info-section" style="margin-bottom: 20px; padding: 20px; background: #f8f9fa; border-radius: 8px; border: 1px solid #ddd;">
            <h3 style="margin-top: 0; margin-bottom: 15px; color: #2c3e50;">文章信息</h3>

            <div class="form-group" style="margin-bottom: 15px;">
                <label for="title" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">文章标题</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    class="form-control"
                    placeholder="请输入文章标题"
                    style="width: 100%; padding: 10px 15px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px;"
                    required
                />
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label for="author" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">作者</label>
                <input
                    type="text"
                    id="author"
                    name="author"
                    class="form-control"
                    placeholder="请输入作者名称"
                    style="width: 100%; padding: 10px 15px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px;"
                    required
                />
            </div>
        </div>

        <!-- 工具栏 -->
        <div class="toolbar">
            <div class="toolbar-section">
                <button type="button" class="tool-btn" onclick="formatText('h1')" title="标题1">
                    H1
                </button>
                <button type="button" class="tool-btn" onclick="formatText('h2')" title="标题2">
                    H2
                </button>
                <button type="button" class="tool-btn" onclick="formatText('h3')" title="标题3">
                    H3
                </button>
                <button type="button" class="tool-btn" onclick="formatText('bold')" title="加粗">
                    <b>B</b>
                </button>
                <button type="button" class="tool-btn" onclick="formatText('italic')" title="斜体">
                    <i>I</i>
                </button>
                <button type="button" class="tool-btn" onclick="formatText('underline')" title="下划线">
                    <u>U</u>
                </button>
            </div>

            <div class="toolbar-section">
                <button type="button" class="tool-btn" onclick="formatText('code')" title="代码块">
                    &lt;/&gt;
                </button>
                <button type="button" class="tool-btn" onclick="formatText('highlight')" title="高亮块">
                    <span style="background-color: yellow;">HL</span>
                </button>
                <button type="button" class="tool-btn" onclick="formatText('quote')" title="引用">
                    ❝
                </button>
                <button type="button" class="tool-btn" onclick="formatText('list')" title="列表">
                    • List
                </button>
                <button type="button" class="tool-btn" onclick="formatText('link')" title="链接">
                    🔗
                </button>
            </div>

            <div class="toolbar-section">
                <div class="color-picker">
                    <label for="text-color">文字颜色:</label>
                    <input type="color" id="text-color" value="#000000" onchange="changeTextColor(this.value)">
                </div>
                <div class="color-picker">
                    <label for="bg-color">背景颜色:</label>
                    <input type="color" id="bg-color" value="#ffffff" onchange="changeBgColor(this.value)">
                </div>
                <button type="button" class="tool-btn" onclick="clearFormat()" title="清除格式">
                    🗑️
                </button>
            </div>
        </div>

        <!-- 编辑区域 -->
        <div class="editor-wrapper">
            <div class="editor-area">
                <textarea
                    id="text"
                    name="text"
                    class="blog-editor"
                    placeholder="开始撰写你的博客..."
                    rows="20"
                    required
                ></textarea>

                <!-- 预览区域 -->
                <div class="preview-area">
                    <h3>实时预览</h3>
                    <div id="preview" class="preview-content"></div>
                </div>

                <!-- 发布按钮 -->
                <div class="submit-section">
                    <button type="submit" class="submit-btn">
                        🚀 发布博客
                    </button>
                </div>
            </div>
        </div>
    </form>

    <!-- 以下样式和脚本部分保持不变 -->
    <style>
        /* 原有样式代码 */
        .editor-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .toolbar {
            background: #f5f5f5;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            border: 1px solid #ddd;
        }

        .toolbar-section {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .tool-btn {
            padding: 8px 12px;
            background: white;
            border: 1px solid #ccc;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }

        .tool-btn:hover {
            background: #e9e9e9;
            transform: translateY(-1px);
        }

        .tool-btn:active {
            transform: translateY(0);
        }

        .color-picker {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .color-picker label {
            font-size: 14px;
            color: #666;
        }

        .color-picker input[type="color"] {
            width: 40px;
            height: 30px;
            border: 1px solid #ccc;
            border-radius: 4px;
            cursor: pointer;
        }

        .editor-wrapper {
            background: white;
            border-radius: 8px;
            border: 1px solid #ddd;
            overflow: hidden;
        }

        .editor-area {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            padding: 20px;
        }

        @media (max-width: 768px) {
            .editor-area {
                grid-template-columns: 1fr;
            }
        }

        .blog-editor {
            width: 100%;
            padding: 15px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
            font-size: 14px;
            line-height: 1.6;
            resize: vertical;
            min-height: 400px;
        }

        .blog-editor:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 0 2px rgba(52, 152, 219, 0.2);
        }

        .preview-area {
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 15px;
            background: #fafafa;
        }

        .preview-area h3 {
            margin-top: 0;
            margin-bottom: 15px;
            color: #333;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
        }

        .preview-content {
            min-height: 370px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: #333;
        }

        .submit-section {
            padding: 20px;
            background: #f9f9f9;
            border-top: 1px solid #ddd;
            text-align: right;
        }

        .submit-btn {
            padding: 12px 30px;
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }

        .submit-btn:hover {
            background: linear-gradient(135deg, #2980b9, #1c5a7a);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
        }

        .submit-btn:active {
            transform: translateY(0);
        }

        /* 预览样式 */
        .preview-content h1 {
            font-size: 2em;
            margin: 0.67em 0;
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 10px;
        }

        .preview-content h2 {
            font-size: 1.5em;
            margin: 0.83em 0;
            color: #34495e;
        }

        .preview-content h3 {
            font-size: 1.17em;
            margin: 1em 0;
            color: #7f8c8d;
        }

        .preview-content b, .preview-content strong {
            font-weight: bold;
        }

        .preview-content i, .preview-content em {
            font-style: italic;
        }

        .preview-content u {
            text-decoration: underline;
        }

        .preview-content code {
            background: #f8f8f8;
            padding: 2px 6px;
            border-radius: 3px;
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 0.9em;
            border: 1px solid #e1e1e1;
        }

        .preview-content pre {
            background: #2d2d2d;
            color: #f8f8f2;
            padding: 15px;
            border-radius: 5px;
            overflow-x: auto;
            margin: 15px 0;
        }

        .preview-content blockquote {
            border-left: 4px solid #3498db;
            margin: 15px 0;
            padding: 10px 20px;
            background: #f8f9fa;
            color: #555;
        }

        .preview-content ul, .preview-content ol {
            padding-left: 30px;
            margin: 10px 0;
        }

        .preview-content a {
            color: #3498db;
            text-decoration: none;
        }

        .preview-content a:hover {
            text-decoration: underline;
        }
    </style>

    <script>
        // 获取编辑器元素
        const editor = document.getElementById('text');
        const preview = document.getElementById('preview');
        const titleInput = document.getElementById('title');
        const authorInput = document.getElementById('author');

        // 实时预览
        editor.addEventListener('input', updatePreview);

        function updatePreview() {
            let content = editor.value;

            // Markdown 转换（简化版）
            content = content
                .replace(/^# (.*$)/gm, '<h1>$1</h1>')
                .replace(/^## (.*$)/gm, '<h2>$1</h2>')
                .replace(/^### (.*$)/gm, '<h3>$1</h3>')
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.*?)\*/g, '<em>$1</em>')
                .replace(/__(.*?)__/g, '<u>$1</u>')
                .replace(/`([^`]+)`/g, '<code>$1</code>')
                .replace(/```([\s\S]*?)```/g, '<pre><code>$1</code></pre>')
                .replace(/^> (.*$)/gm, '<blockquote>$1</blockquote>')
                .replace(/^- (.*$)/gm, '<li>$1</li>')
                .replace(/\n/g, '<br>');

            preview.innerHTML = content;
        }

        // 文本格式化函数
        function formatText(type) {
            const start = editor.selectionStart;
            const end = editor.selectionEnd;
            const selectedText = editor.value.substring(start, end);
            let formattedText = '';

            switch(type) {
                case 'h1':
                    formattedText = `# ${selectedText || '标题1'}`;
                    break;
                case 'h2':
                    formattedText = `## ${selectedText || '标题2'}`;
                    break;
                case 'h3':
                    formattedText = `### ${selectedText || '标题3'}`;
                    break;
                case 'bold':
                    formattedText = `**${selectedText || '加粗文本'}**`;
                    break;
                case 'italic':
                    formattedText = `*${selectedText || '斜体文本'}*`;
                    break;
                case 'underline':
                    formattedText = `__${selectedText || '下划线文本'}__`;
                    break;
                case 'code':
                    formattedText = `\`${selectedText || '代码'}\``;
                    break;
                case 'highlight':
                    formattedText = `==${selectedText || '高亮文本'}==`;
                    break;
                case 'quote':
                    formattedText = `> ${selectedText || '引用文本'}`;
                    break;
                case 'list':
                    formattedText = `- ${selectedText || '列表项'}`;
                    break;
                case 'link':
                    const url = prompt('请输入链接地址:', 'https://');
                    if (url) {
                        formattedText = `[${selectedText || '链接文本'}](${url})`;
                    } else {
                        return;
                    }
                    break;
            }

            // 插入格式化文本
            editor.value = editor.value.substring(0, start) + formattedText + editor.value.substring(end);

            // 更新预览
            updatePreview();

            // 恢复焦点
            editor.focus();
            editor.setSelectionRange(start + formattedText.length, start + formattedText.length);
        }

        // 改变文字颜色
        function changeTextColor(color) {
            insertAtCursor(`<span style="color: ${color};">`, `</span>`);
        }

        // 改变背景颜色
        function changeBgColor(color) {
            insertAtCursor(`<span style="background-color: ${color};">`, `</span>`);
        }

        // 清除格式
        function clearFormat() {
            const start = editor.selectionStart;
            const end = editor.selectionEnd;
            const selectedText = editor.value.substring(start, end);

            // 移除常见格式标记
            let cleanText = selectedText
                .replace(/[#*_`>~\[\](){}]/g, '')
                .replace(/<\/?[^>]+(>|$)/g, '');

            editor.value = editor.value.substring(0, start) + cleanText + editor.value.substring(end);
            updatePreview();
            editor.focus();
        }

        // 辅助函数：在光标位置插入文本
        function insertAtCursor(startTag, endTag) {
            const start = editor.selectionStart;
            const end = editor.selectionEnd;
            const selectedText = editor.value.substring(start, end);

            editor.value = editor.value.substring(0, start) +
                          startTag + selectedText + endTag +
                          editor.value.substring(end);

            updatePreview();
            editor.focus();
            editor.setSelectionRange(start + startTag.length, start + startTag.length + selectedText.length);
        }

        // 初始化预览
        updatePreview();

        // 表单提交处理
        document.getElementById('blog-form').addEventListener('submit', function(e) {
            // 验证标题
            if (!titleInput.value.trim()) {
                e.preventDefault();
                alert('文章标题不能为空！');
                titleInput.focus();
                return;
            }

            // 验证作者
            if (!authorInput.value.trim()) {
                e.preventDefault();
                alert('作者名称不能为空！');
                authorInput.focus();
                return;
            }

            // 验证内容
            if (!editor.value.trim()) {
                e.preventDefault();
                alert('博客内容不能为空！');
                editor.focus();
                return;
            }

            // 可以在这里添加提交前的其他处理，比如显示加载状态等
            console.log('提交文章信息：');
            console.log('标题：', titleInput.value);
            console.log('作者：', authorInput.value);
            console.log('内容：', editor.value);
        });
    </script>
{{end}}