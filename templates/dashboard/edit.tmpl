{{ template "layout" . }}
{{define "title"}}博客编辑{{end}}
{{define "content"}}
<div class="editor-container">
    <h1>博客编辑器</h1>

    <!-- 整个表单包裹，标题/类型输入框也属于表单 -->
    <form id="blog-form" action="/blog/admin/{{.id}}/dashboard/edit" method="POST">
        <!-- 文章标题和类型输入区域 -->
        <div class="article-info-section" style="margin-bottom: 20px; padding: 20px; background: #f8f9fa; border-radius: 8px; border: 1px solid #ddd;">
            <h3 style="margin-top: 0; margin-bottom: 15px; color: #2c3e50;">文章信息</h3>

            <div class="form-group" style="margin-bottom: 15px;">
                <label for="title" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">文章标题</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    class="form-control"
                    placeholder="请输入文章标题"
                    style="width: 100%; padding: 10px 15px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px;"
                    required
                />
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label for="typer" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">博客类型</label>
                <input
                    type="text"
                    id="typer"
                    name="type"
                    class="form-control"
                    placeholder="请输入博客类型"
                    style="width: 100%; padding: 10px 15px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px;"
                    required
                />
            </div>
        </div>

        <!-- 工具栏：仅保留标准 Markdown 语法按钮 -->
        <div class="toolbar">
            <div class="toolbar-section">
                <button type="button" class="tool-btn" onclick="formatText('h1')" title="标题1">H1</button>
                <button type="button" class="tool-btn" onclick="formatText('h2')" title="标题2">H2</button>
                <button type="button" class="tool-btn" onclick="formatText('h3')" title="标题3">H3</button>
                <button type="button" class="tool-btn" onclick="formatText('bold')" title="加粗"><b>B</b></button>
                <button type="button" class="tool-btn" onclick="formatText('italic')" title="斜体"><i>I</i></button>
                <button type="button" class="tool-btn" onclick="formatText('underline')" title="下划线"><u>U</u></button>
                <button type="button" class="tool-btn" onclick="formatText('strikethrough')" title="删除线"><s>S</s></button>
            </div>
            <div class="toolbar-section">
                <button type="button" class="tool-btn" onclick="formatText('code')" title="行内代码">&lt;/&gt;</button>
                <button type="button" class="tool-btn" onclick="formatText('codeblock')" title="代码块">```</button>
                <button type="button" class="tool-btn" onclick="formatText('quote')" title="引用">❝</button>
                <button type="button" class="tool-btn" onclick="formatText('list')" title="无序列表">• List</button>
                <button type="button" class="tool-btn" onclick="formatText('orderedlist')" title="有序列表">1.</button>
                <button type="button" class="tool-btn" onclick="formatText('link')" title="链接">🔗</button>
                <button type="button" class="tool-btn" onclick="formatText('image')" title="图片">🖼️</button>
                <button type="button" class="tool-btn" onclick="formatText('hr')" title="水平线">—</button>
            </div>
        </div>

        <!-- 编辑区域 -->
        <div class="editor-wrapper">
            <div class="editor-area">
                <textarea
                    id="text"
                    name="text"
                    class="blog-editor"
                    placeholder="开始撰写你的博客（支持 Markdown 语法）..."
                    rows="20"
                    required
                ></textarea>

                <!-- 预览区域 -->
                <div class="preview-area">
                    <h3>实时预览</h3>
                    <div id="preview" class="preview-content"></div>
                </div>

                <!-- 发布按钮 -->
                <div class="submit-section">
                    <button type="submit" class="submit-btn">🚀 发布博客</button>
                </div>
            </div>
        </div>
    </form>

    <!-- 样式（保持不变） -->
    <style>
        .editor-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .toolbar {
            background: #f5f5f5;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            border: 1px solid #ddd;
        }
        .toolbar-section {
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .tool-btn {
            padding: 8px 12px;
            background: white;
            border: 1px solid #ccc;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }
        .tool-btn:hover {
            background: #e9e9e9;
            transform: translateY(-1px);
        }
        .tool-btn:active {
            transform: translateY(0);
        }
        .editor-wrapper {
            background: white;
            border-radius: 8px;
            border: 1px solid #ddd;
            overflow: hidden;
        }
        .editor-area {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            padding: 20px;
        }
        @media (max-width: 768px) {
            .editor-area {
                grid-template-columns: 1fr;
            }
        }
        .blog-editor {
            width: 100%;
            padding: 15px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
            font-size: 14px;
            line-height: 1.6;
            resize: vertical;
            min-height: 400px;
        }
        .blog-editor:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 0 2px rgba(52, 152, 219, 0.2);
        }
        .preview-area {
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 15px;
            background: #fafafa;
        }
        .preview-area h3 {
            margin-top: 0;
            margin-bottom: 15px;
            color: #333;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
        }
        .preview-content {
            min-height: 370px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: #333;
        }
        .submit-section {
            padding: 20px;
            background: #f9f9f9;
            border-top: 1px solid #ddd;
            text-align: right;
        }
        .submit-btn {
            padding: 12px 30px;
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }
        .submit-btn:hover {
            background: linear-gradient(135deg, #2980b9, #1c5a7a);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
        }
        .submit-btn:active {
            transform: translateY(0);
        }
        /* 预览样式 */
        .preview-content h1 {
            font-size: 2em;
            margin: 0.67em 0;
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 10px;
        }
        .preview-content h2 {
            font-size: 1.5em;
            margin: 0.83em 0;
            color: #34495e;
        }
        .preview-content h3 {
            font-size: 1.17em;
            margin: 1em 0;
            color: #7f8c8d;
        }
        .preview-content strong { font-weight: bold; }
        .preview-content em { font-style: italic; }
        .preview-content del { text-decoration: line-through; }
        .preview-content code {
            background: #f8f8f8;
            padding: 2px 6px;
            border-radius: 3px;
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 0.9em;
            border: 1px solid #e1e1e1;
        }
        .preview-content pre {
            background: #2d2d2d;
            color: #f8f8f2;
            padding: 15px;
            border-radius: 5px;
            overflow-x: auto;
            margin: 15px 0;
        }
        .preview-content pre code {
            background: none;
            border: none;
            padding: 0;
        }
        .preview-content blockquote {
            border-left: 4px solid #3498db;
            margin: 15px 0;
            padding: 10px 20px;
            background: #f8f9fa;
            color: #555;
        }
        .preview-content ul, .preview-content ol {
            padding-left: 30px;
            margin: 10px 0;
        }
        .preview-content a {
            color: #3498db;
            text-decoration: none;
        }
        .preview-content a:hover {
            text-decoration: underline;
        }
        .preview-content hr {
            border: none;
            border-top: 1px solid #ddd;
            margin: 20px 0;
        }
    </style>

    <script>
        // DOM 元素
        const editor = document.getElementById('text');
        const preview = document.getElementById('preview');
        const titleInput = document.getElementById('title');
        const authorInput = document.getElementById('typer'); // 注意 id 为 typer

        // ----- Markdown 解析器（完整）-----
        function escapeHtml(text) {
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function parseMarkdown(markdown) {
            // 先转义 HTML 特殊字符，防止 XSS，但保留 Markdown 标记
            let html = escapeHtml(markdown);

            // 处理代码块（必须在其他行内样式之前）
            html = html.replace(/```([\s\S]*?)```/g, (match, code) => {
                return `<pre><code>${code.trim()}</code></pre>`;
            });

            // 行内代码
            html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

            // 处理标题（行首）
            html = html.replace(/^### (.*$)/gm, '<h3>$1</h3>');
            html = html.replace(/^## (.*$)/gm, '<h2>$1</h2>');
            html = html.replace(/^# (.*$)/gm, '<h1>$1</h1>');

            // 粗体、斜体、删除线（注意顺序避免冲突）
            html = html.replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>');
            html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
            html = html.replace(/__(.*?)__/g, '<strong>$1</strong>');
            html = html.replace(/_(.*?)_/g, '<em>$1</em>');
            html = html.replace(/~~(.*?)~~/g, '<del>$1</del>');

            // 链接和图片
            html = html.replace(/!\[(.*?)\]\((.*?)\)/g, '<img src="$2" alt="$1" style="max-width:100%">');
            html = html.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank">$1</a>');

            // 水平线
            html = html.replace(/^---$/gm, '<hr>');

            // 引用块（处理连续的行）
            let lines = html.split('\n');
            let inQuote = false;
            let quoteLines = [];
            let result = [];
            for (let i = 0; i < lines.length; i++) {
                let line = lines[i];
                if (line.startsWith('&gt;')) {
                    if (!inQuote) {
                        inQuote = true;
                        quoteLines = [];
                    }
                    quoteLines.push(line.replace(/^&gt; /, ''));
                } else {
                    if (inQuote) {
                        result.push('<blockquote>' + quoteLines.join('<br>') + '</blockquote>');
                        inQuote = false;
                    }
                    result.push(line);
                }
            }
            if (inQuote) result.push('<blockquote>' + quoteLines.join('<br>') + '</blockquote>');
            html = result.join('\n');

            // 列表（无序和有序）
            // 先处理无序列表
            let inList = false;
            let listItems = [];
            let listType = null;
            const newLines = [];
            const linesArr = html.split('\n');
            for (let i = 0; i < linesArr.length; i++) {
                let line = linesArr[i];
                const ulMatch = line.match(/^[-*+] (.*)$/);
                const olMatch = line.match(/^\d+\. (.*)$/);
                if (ulMatch) {
                    if (!inList || listType !== 'ul') {
                        if (inList) newLines.push(listType === 'ul' ? '<ul>' + listItems.join('') + '</ul>' : '<ol>' + listItems.join('') + '</ol>');
                        inList = true;
                        listType = 'ul';
                        listItems = [];
                    }
                    listItems.push('<li>' + ulMatch[1] + '</li>');
                } else if (olMatch) {
                    if (!inList || listType !== 'ol') {
                        if (inList) newLines.push(listType === 'ul' ? '<ul>' + listItems.join('') + '</ul>' : '<ol>' + listItems.join('') + '</ol>');
                        inList = true;
                        listType = 'ol';
                        listItems = [];
                    }
                    listItems.push('<li>' + olMatch[1] + '</li>');
                } else {
                    if (inList) {
                        newLines.push(listType === 'ul' ? '<ul>' + listItems.join('') + '</ul>' : '<ol>' + listItems.join('') + '</ol>');
                        inList = false;
                    }
                    newLines.push(line);
                }
            }
            if (inList) newLines.push(listType === 'ul' ? '<ul>' + listItems.join('') + '</ul>' : '<ol>' + listItems.join('') + '</ol>');
            html = newLines.join('\n');

            // 段落：将连续的非空行用 <p> 包裹
            const paragraphs = html.split(/\n\s*\n/);
            html = paragraphs.map(p => {
                p = p.trim();
                if (p && !p.startsWith('<') && !p.startsWith('&') && !p.startsWith('```')) {
                    return `<p>${p.replace(/\n/g, '<br>')}</p>`;
                }
                return p;
            }).join('\n');

            return html;
        }

        // 实时预览
        function updatePreview() {
            const markdownText = editor.value;
            const htmlContent = parseMarkdown(markdownText);
            preview.innerHTML = htmlContent;
        }

        editor.addEventListener('input', updatePreview);

        // 文本格式化函数（插入标准 Markdown 标记）
        function formatText(type) {
            const start = editor.selectionStart;
            const end = editor.selectionEnd;
            const selectedText = editor.value.substring(start, end);
            let formattedText = '';
            let cursorOffset = 0;

            switch(type) {
                case 'h1':
                    formattedText = `# ${selectedText || '标题1'}`;
                    cursorOffset = 2;
                    break;
                case 'h2':
                    formattedText = `## ${selectedText || '标题2'}`;
                    cursorOffset = 3;
                    break;
                case 'h3':
                    formattedText = `### ${selectedText || '标题3'}`;
                    cursorOffset = 4;
                    break;
                case 'bold':
                    formattedText = `**${selectedText || '加粗文本'}**`;
                    cursorOffset = 2;
                    break;
                case 'italic':
                    formattedText = `*${selectedText || '斜体文本'}*`;
                    cursorOffset = 1;
                    break;
                case 'underline':
                    formattedText = `__${selectedText || '下划线文本'}__`;
                    cursorOffset = 2;
                    break;
                case 'strikethrough':
                    formattedText = `~~${selectedText || '删除线文本'}~~`;
                    cursorOffset = 2;
                    break;
                case 'code':
                    formattedText = `\`${selectedText || '代码'}\``;
                    cursorOffset = 1;
                    break;
                case 'codeblock':
                    formattedText = `\n\`\`\`\n${selectedText || '代码块'}\n\`\`\`\n`;
                    cursorOffset = 5;
                    break;
                case 'quote':
                    formattedText = `> ${selectedText || '引用文本'}`;
                    cursorOffset = 2;
                    break;
                case 'list':
                    if (selectedText.includes('\n')) {
                        formattedText = selectedText.split('\n').map(line => `- ${line}`).join('\n');
                    } else {
                        formattedText = `- ${selectedText || '列表项'}`;
                    }
                    cursorOffset = 2;
                    break;
                case 'orderedlist':
                    if (selectedText.includes('\n')) {
                        formattedText = selectedText.split('\n').map((line, idx) => `${idx+1}. ${line}`).join('\n');
                    } else {
                        formattedText = `1. ${selectedText || '列表项'}`;
                    }
                    cursorOffset = 3;
                    break;
                case 'link':
                    const url = prompt('请输入链接地址:', 'https://');
                    if (url) {
                        formattedText = `[${selectedText || '链接文本'}](${url})`;
                        cursorOffset = selectedText ? 1 : 0;
                    } else {
                        return;
                    }
                    break;
                case 'image':
                    const imgUrl = prompt('请输入图片地址:', 'https://');
                    const alt = prompt('请输入图片描述:', '图片');
                    if (imgUrl) {
                        formattedText = `![${alt || '图片'}](${imgUrl})`;
                        cursorOffset = alt ? 2 : 0;
                    } else {
                        return;
                    }
                    break;
                case 'hr':
                    formattedText = '\n---\n';
                    cursorOffset = 0;
                    break;
                default:
                    return;
            }

            // 插入文本
            editor.value = editor.value.substring(0, start) + formattedText + editor.value.substring(end);
            updatePreview();

            // 恢复焦点并设置光标位置
            editor.focus();
            const newCursorPos = start + formattedText.length - (selectedText ? cursorOffset : 0);
            editor.setSelectionRange(newCursorPos, newCursorPos);
        }

        // 初始化预览
        updatePreview();

        // 表单提交验证
        document.getElementById('blog-form').addEventListener('submit', function(e) {
            if (!titleInput.value.trim()) {
                e.preventDefault();
                alert('文章标题不能为空！');
                titleInput.focus();
                return;
            }
            if (!authorInput.value.trim()) {
                e.preventDefault();
                alert('博客类型不能为空！');
                authorInput.focus();
                return;
            }
            if (!editor.value.trim()) {
                e.preventDefault();
                alert('博客内容不能为空！');
                editor.focus();
                return;
            }
        });
    </script>
{{end}}